{
  "always_run_in_app" : false,
  "icon" : {
    "color" : "deep-gray",
    "glyph" : "database"
  },
  "name" : "Base",
  "script" : "\/\/ Author: ceyedev\n\/\/ Created: 01-12-2025\n\/\/ Last Modified: 13-07-2026\n\/\/ Version: 1.2.8\n\/\/ Description: This scripts includes various classes to create fancy widgets and ease the process of building Scriptable scripts.\n\/\/ License: MIT\n\/\/ Repository: github.com\/ceyedev\/Scriptable\n\/\/ Modules: FancyText, FancyImage, invertColor, getContrastColor, hueShift, cleanColor, averageColor, adjustBrightness, createRandomColor\n\/\/ Usage: let Base = importModule(\"Base\");\n\/\/        let fancyText = new Base.FancyText()\n\/\/        let final = await fancyText.setText(\"Hello World\").setSize(300, 100).create();\n\n\nclass FancyText {\n  setText(t) {\n    this.text = t\n    return this\n  }\n\n  setSize(w, h) {\n    this.width = w\n    this.height = h\n    return this\n  }\n\n  setFontColor(from, to = null) {\n    this.fontColorFrom = `#${(from.hex ?? String(from)).replace(\/^#\/, \"\")}`\n    this.fontColorTo = to ? `#${(to.hex ?? String(to)).replace(\/^#\/, \"\")}` : this.fontColorFrom\n    return this\n  }\n\n  setFontName(name) {\n    this.fontName = name\n    return this\n  }\n\n  setFontStyle(style) {\n    this.fontStyle = style\n    return this\n  }\n\n  setFontSize(min, max) {\n    this.minFont = min\n    this.maxFont = max\n    return this\n  }\n\n  setFont(colorFrom, colorTo, name, style, minSize, maxSize) {\n    this.fontColorFrom = `#${(colorFrom.hex ?? String(colorFrom)).replace(\/^#\/, \"\")}`\n    this.fontColorTo = `#${(colorTo.hex ?? String(colorTo)).replace(\/^#\/, \"\")}`\n    this.fontName = name\n    this.fontStyle = style\n    this.minFont = minSize\n    this.maxFont = maxSize\n    return this\n  }\n\n  setAlign(alignX, alignY) {\n    this.alignX = alignX\n    this.alignY = alignY\n    return this\n  }\n\n  setOutline(color = \"#000000\", width = 2) {\n    this.outlineColor = `#${(color.hex ?? String(color)).replace(\/^#\/, \"\")}`\n    this.outlineWidth = width\n    return this\n  }\n\n  setShadow(color = \"#000000\", offsetX = 2, offsetY = 2, blur = 3) {\n    this.shadowColor = `#${(color.hex ?? String(color)).replace(\/^#\/, \"\")}`\n    this.shadowOffsetX = offsetX\n    this.shadowOffsetY = offsetY\n    this.shadowBlur = blur\n    return this\n  }\n\n  setPadding(top = 3, bottom = 3, left = 2, right = 2) {\n    this.paddingTop = top\n    this.paddingBottom = bottom\n    this.paddingLeft = left\n    this.paddingRight = right\n    return this\n  }\n\n  setStack(onStack, showBounds = false) {\n    this.onStack = onStack\n    this.showBounds = showBounds\n    return this\n  }\n\n  constructor() {\n    this.text = \"\"\n    this.width = 200\n    this.height = 40\n    this.fontColorFrom = \"#00ff88\"\n    this.fontColorTo = \"#00e1ff\"\n    this.minFont = 10\n    this.maxFont = 1000\n    this.alignX = \"\"\n    this.alignY = \"\"\n    this.fontName = \"Avenir\"\n    this.fontStyle = \"bold\"\n    this.outlineColor = \"#000000\"\n    this.outlineWidth = 0\n    this.shadowColor = \"#000000\"\n    this.shadowOffsetX = 0\n    this.shadowOffsetY = 0\n    this.shadowBlur = 0\n    this.paddingTop = 3\n    this.paddingBottom = 3\n    this.paddingLeft = 2\n    this.paddingRight = 2\n\n    this.onStack = null\n    this.showBounds = false\n  }\n\n  async create() {\n    this.minFont = Math.max(this.minFont, 0)\n    this.maxFont = Math.max(this.maxFont, this.minFont)\n    this.width = Math.max(this.width, 0)\n    this.height = Math.max(this.height, 0)\n    this.outlineWidth = Math.max(this.outlineWidth, 0)\n    this.shadowBlur = Math.max(this.shadowBlur, -1)\n    if (this.outlineWidth <= 0 && this.shadowBlur > 0) this.outlineColor = this.shadowColor\n\n    let html = `\n      <!DOCTYPE html>\n      <html>\n      <body style=\"margin:0\">\n      <canvas id=\"c\"><\/canvas>\n      <script>\n        let dpr = window.devicePixelRatio || 2;\n        let canvas = document.getElementById(\"c\");\n        canvas.width = ${this.width} * dpr;\n        canvas.height = ${this.height} * dpr;\n        canvas.style.width = ${this.width} + \"px\";\n        canvas.style.height = ${this.height} + \"px\";\n        let ctx = canvas.getContext(\"2d\");\n        ctx.scale(dpr, dpr);\n\n        let text = \"${this.text.replace(\/\"\/g, '\\\\\"')}\";\n        let fontSize = ${this.maxFont};\n\n        while(fontSize >= ${this.minFont}) {\n          ctx.font = \"${this.fontStyle} \" + fontSize + \"px ${this.fontName}\";\n          let metrics = ctx.measureText(text);\n          let textWidth = metrics.width + ${this.paddingLeft} + ${this.paddingRight};\n          let textHeight = metrics.actualBoundingBoxAscent + metrics.actualBoundingBoxDescent + ${this.paddingTop} + ${this.paddingBottom};\n          if(textWidth <= ${this.width} && textHeight <= ${this.height}) break;\n          fontSize -= 1;\n        }\n\n        ctx.font = \"${this.fontStyle} \" + fontSize + \"px ${this.fontName}\";\n\n        if (${this.shadowBlur} >= 0) {\n          ctx.shadowColor = \"${this.shadowColor}\";\n          ctx.shadowOffsetX = ${this.shadowOffsetX};\n          ctx.shadowOffsetY = ${this.shadowOffsetY};\n          ctx.shadowBlur = ${this.shadowBlur};\n        } else {\n          ctx.shadowColor = \"transparent\";\n          ctx.shadowOffsetX = 0;\n          ctx.shadowOffsetY = 0;\n          ctx.shadowBlur = 0;\n        }\n\n        let gradient = ctx.createLinearGradient(0,0,${this.width},0);\n        gradient.addColorStop(0,\"${this.fontColorFrom}\");\n        gradient.addColorStop(1,\"${this.fontColorTo}\");\n        ctx.fillStyle = gradient;\n\n        ctx.textBaseline = \"alphabetic\";\n        let metrics = ctx.measureText(text);\n        let ascent = metrics.actualBoundingBoxAscent;\n        let descent = metrics.actualBoundingBoxDescent;\n        let textWidth = metrics.width;\n        let textHeight = ascent + descent;\n\n        let x, y;\n\n        if (\"${this.alignX}\" === \"left\") {\n          x = ${this.paddingLeft};\n        } else if (\"${this.alignX}\" === \"right\") {\n          x = ${this.width} - ${this.paddingRight} - textWidth;\n        } else { \/\/ center\n          x = (${this.width} - textWidth)\/2 + (${this.paddingLeft} - ${this.paddingRight})\/2;\n        }\n\n        if (\"${this.alignY}\" === \"top\") {\n          y = ascent + ${this.paddingTop};\n        } else if (\"${this.alignY}\" === \"bottom\") {\n          y = ${this.height} - descent - ${this.paddingBottom};\n        } else { \/\/ middle\n          y = ${this.height}\/2 + (${this.paddingTop} - ${this.paddingBottom})\/2 + (ascent - textHeight\/2);\n        }\n\n        if (${this.outlineWidth} > 0) {\n          ctx.lineWidth = ${this.outlineWidth}\n          ctx.strokeStyle = \"${this.outlineColor}\"\n          ctx.strokeText(text, x, y)\n        }\n\n\t\t\t\tctx.fillText(text, x, y)\n\n        window.finalImage = canvas.toDataURL(\"image\/png\");\n      <\/script>\n      <\/body>\n      <\/html>\n      `;\n\n    let wv = new WebView();\n    await wv.loadHTML(html);\n    let dataUrl = await wv.evaluateJavaScript(\"window.finalImage\");\n    let req = new Request(dataUrl);\n    let img = await req.loadImage();\n\n    if (this.onStack) {\n      let newStack = this.onStack.addStack()\n      newStack.addImage(img)\n      if (this.showBounds) {\n        newStack.borderWidth = 2\n        newStack.borderColor = Color.blue()\n      }\n      newStack.size = new Size(this.width, this.height)\n      return newStack\n    }\n    else {\n      return img\n    }\n  }\n}\n\n\nclass FancyImage {\n  setUrl(imgUrl) {\n    this.imgUrl = imgUrl\n    return this\n  }\n\n  setSize(w, h=-1) {\n    this.width = w\n    this.height = h == -1 ? w : h\n    return this\n  }\n\n  setRadius(radius) {\n    this.radius = radius\n    return this\n  }\n\n  setOutline(outlineWidth, tl, tr, bl, br) {\n    this.outlineWidth = outlineWidth\n    tl = tl ? tl : \"#000\"\n    this.color1 = cleanColor(tl)\n    this.color2 = cleanColor(tr ? tr : tl)\n    this.color3 = cleanColor(bl ? bl : tr ? tr : tl)\n    this.color4 = cleanColor(br ? br : bl ? bl : tr ? tr : tl)\n    return this\n  }\n\n  setOutlineBG(tl, tr, bl, br) {\n    tl = tl ? tl : \"#000\"\n    this.bgColor1 = cleanColor(tl)\n    this.bgColor2 = cleanColor(tr ? tr : tl)\n    this.bgColor3 = cleanColor(bl ? bl : tr ? tr : tl)\n    this.bgColor4 = cleanColor(br ? br : bl ? bl : tr ? tr : tl)\n    return this\n  }\n\n  setShadow(shadowBlur = 20, shadowColor = \"#000\", offsetX = 0, offsetY = 0, shadowMode = 1) {\n    this.shadowBlur = shadowBlur\n    this.shadowColor = cleanColor(shadowColor)\n    this.shadowOffsetX = offsetX\n    this.shadowOffsetY = offsetY\n    this.shadowMode = shadowMode\n    return this\n  }\n\n  setGlow(blur, color){\n    this.outlineGlowBlur = blur\n    this.outlineGlowColor = cleanColor(color)\n    return this\n  }\n  \n  setCut(cutImage = true) {\n    this.cutImage = cutImage\n    return this\n  }\n\n  setStack(onStack, showBounds = false) {\n    this.onStack = onStack\n    this.showBounds = showBounds\n    return this\n  }\n  \n  setValue(value) {\n    this.value = value\n    return this\n  }\n  \n  setBase64(image){\n    this.imageBase64 = image instanceof Image ? Data.fromPNG(image).toBase64String() : image\n    return this\n  }\n\n  constructor() {\n    this.imgUrl = \"\"\n    this.imageBase64 = \"NaN\"\n    this.color1 = Color.yellow().hex\n    this.color2 = Color.green().hex\n    this.color3 = Color.red().hex\n    this.color4 = Color.blue().hex\n    this.bgColor1 = \"#000\"\n    this.bgColor2 = \"#000\"\n    this.bgColor3 = \"#000\"\n    this.bgColor4 = \"#000\"\n    this.width = 150\n    this.height = 150\n    this.outlineWidth = 5\n    this.radius = 50\n    this.value = 1\n    this.stretchImage = false\n\n    this.shadowColor = '#fff'\n    this.shadowBlur = 20\n    this.shadowOffsetX = 0\n    this.shadowOffsetY = 0\n    this.shadowMode = 1  \/\/ 1 = normal, 2 = filled. Recommended: with outline 1, without 2\n\n    this.outlineGlowColor = \"#fff\"\n    this.outlineGlowBlur = 0\n\n\n    this.onStack = null\n    this.showBounds = false\n  }\n\n  async create() {\n    this.width = Math.max(this.width, 0)\n    this.height = Math.max(this.height, 0)\n    this.outlineWidth = Math.max(this.outlineWidth, 0)\n    this.radius = Math.max(this.radius, 0)\n    this.shadowBlur = Math.max(this.shadowBlur, 0)\n    this.value = Math.max(0, Math.min(1, this.value));\n    this.shadowMode = Math.round(Math.max(0, Math.min(1, this.shadowMode)));\n    this.shadowOffsetX = Math.max(this.shadowOffsetX, 0)\n    this.shadowOffsetY = Math.max(this.shadowOffsetY, 0)\n\n\n    let html = `\n      <!DOCTYPE html>\n      <html>\n      <body style=\"margin:0\">\n      <canvas id=\"c\"><\/canvas>\n      <script>\n      let color1 = \"${this.color2}\";\n      let color2 = \"${this.color3}\";\n      let color3 = \"${this.color4}\";\n      let color4 = \"${this.color1}\";\n      let bgColor1 = \"${this.bgColor1}\";\n      let bgColor2 = \"${this.bgColor2}\";\n      let bgColor3 = \"${this.bgColor3}\";\n      let bgColor4 = \"${this.bgColor4}\";\n      let width = Number(${this.width});\n      let height = Number(${this.height});\n      let outlineWidth = Number(${this.outlineWidth});\n      let radius = Number(${this.radius});\n      let value = Number(${this.value});\n      let stretchImage = ${this.stretchImage};\n      let shadowColor = \"${this.shadowColor}\";\n      let shadowBlur = Number(${this.shadowBlur});\n      let shadowOffsetX = Number(${this.shadowOffsetX});\n      let shadowOffsetY = Number(${this.shadowOffsetY});\n      let shadowMode = Number(${this.shadowMode});\n      let outlineGlowColor = \"${this.outlineGlowColor}\";\n      let outlineGlowBlur = Number(${this.outlineGlowBlur});\n      \n      value = Math.max(0, Math.min(1, isFinite(value) ? value : 0));\n      let percent = value * 100;\n      \n      height = Math.max(height, outlineWidth * 2);\n      width = Math.max(width, outlineWidth * 2);\n      \n      function hexToRgb(hex){\n        hex = String(hex).replace('#','');\n        if(hex.length===3) hex = hex.split('').map(c=>c+c).join('');\n        let num = parseInt(hex,16) || 0;\n        return [(num>>16)&255,(num>>8)&255,num&255];\n      }\n      function lerp(a,b,t){ return a + (b - a) * t }\n      function mix(c1,c2,t){ return [lerp(c1[0],c2[0],t), lerp(c1[1],c2[1],t), lerp(c1[2],c2[2],t)] }\n      \n      let colourTL = hexToRgb(color4),\n          colourTR = hexToRgb(color1),\n          colourBL = hexToRgb(color3),\n          colourBR = hexToRgb(color2),\n          canvas = document.getElementById('c'),\n          c = canvas.getContext('2d');\n      \n      c.imageSmoothingEnabled = false;\n      \n      let scaleFactor = 3;\n      canvas.width = width * scaleFactor;\n      canvas.height = height * scaleFactor;\n      canvas.style.width = width + \"px\";\n      canvas.style.height = height + \"px\";\n      \n      let lineWidth = outlineWidth * scaleFactor;\n      let shadowPadding = shadowBlur + 1 + Math.max(shadowOffsetX, shadowOffsetY);\n      \n      function createPattern(c1,c2,c3,c4){\n        let gCanvas = document.createElement('canvas');\n        gCanvas.width = canvas.width;\n        gCanvas.height = canvas.height;\n        let g = gCanvas.getContext('2d');\n        let imgData = g.createImageData(gCanvas.width, gCanvas.height);\n        for(let y=0;y<gCanvas.height;y++){\n          let v = y\/(gCanvas.height-1);\n          for(let x=0;x<gCanvas.width;x++){\n            let u = x\/(gCanvas.width-1);\n            let top = mix(c1,c2,u);\n            let bottom = mix(c3,c4,u);\n            let col = mix(top,bottom,v);\n            let i = (y*gCanvas.width+x)*4;\n            imgData.data[i]=col[0];\n            imgData.data[i+1]=col[1];\n            imgData.data[i+2]=col[2];\n            imgData.data[i+3]=255;\n          }\n        }\n        g.putImageData(imgData,0,0);\n        return c.createPattern(gCanvas,'no-repeat');\n      }\n      \n      function drawRoundedProgress(x,y,w,h,r,p){\n        if(lineWidth <= 0) return;\n        let totalLength = 2*(w+h-4*r) + 2*Math.PI*r;\n        let drawLength = totalLength * p\/100;\n        c.beginPath();\n        let remaining = drawLength;\n        let startX = x + w\/2;\n        let startY = y;\n        c.moveTo(startX, startY);\n        let pos = {x:startX, y:startY};\n      \n        function stepLine(dx,dy,len){\n          if(remaining <= 0) return;\n          let t = Math.min(1, remaining\/len);\n          pos.x += dx * t;\n          pos.y += dy * t;\n          c.lineTo(pos.x, pos.y);\n          remaining -= len*t;\n        }\n      \n        function stepArc(cx,cy,start,end){\n          if(remaining <= 0) return;\n          let arcLen = r*(end-start);\n          let t = Math.min(1, remaining\/arcLen);\n          c.arc(cx, cy, r, start, start + (end-start)*t);\n          remaining -= arcLen*t;\n          pos.x = cx + r * Math.cos(start + (end-start)*t);\n          pos.y = cy + r * Math.sin(start + (end-start)*t);\n        }\n      \n        stepLine(w\/2-r,0,w\/2-r);\n        stepArc(x+w-r,y+r,-Math.PI\/2,0);\n        stepLine(0,h-2*r,h-2*r);\n        stepArc(x+w-r,y+h-r,0,Math.PI\/2);\n        stepLine(-w+2*r,0,w-2*r);\n        stepArc(x+r,y+h-r,Math.PI\/2,Math.PI);\n        stepLine(0,-h+2*r,h-2*r);\n        stepArc(x+r,y+r,Math.PI,3*Math.PI\/2);\n        stepLine(w\/2-r,0,w\/2-r);\n        c.stroke();\n      }\n      \n      \n      let img = new Image();\n      img.crossOrigin = 'anonymous';\n      \n      if(\"${this.imageBase64}\" == \"NaN\"){\n        img.src = \"${this.imgUrl}\" || 'https:\/\/art.pixilart.com\/sr5z34ca2d755eaws3.png';\n      }\n      else{\n        img.src = \"data:image\/png;base64,${this.imageBase64}\" || 'https:\/\/art.pixilart.com\/sr5z34ca2d755eaws3.png';\n      }\n      \n      \n      \n      img.onload = () => {\n      \n      let bgTL = hexToRgb(bgColor4),\n          bgTR = hexToRgb(bgColor1),\n          bgBL = hexToRgb(bgColor3),\n          bgBR = hexToRgb(bgColor2);\n      \n      let outlineBG = createPattern(bgTL,bgTR,bgBL,bgBR);\n      \n      c.lineWidth = lineWidth;\n      c.lineCap = 'round';\n      \n      let pad = shadowPadding + lineWidth\/2;\n      c.save();\n      c.shadowColor = shadowColor;\n      c.shadowBlur = shadowBlur;\n      c.shadowOffsetX = shadowOffsetX;\n      c.shadowOffsetY = shadowOffsetY;\n      \n      c.fillStyle = outlineBG;\n      \n      if(shadowMode === 2){\n        c.beginPath();\n        let innerR = Math.max(0, radius - shadowPadding);\n        c.moveTo(pad + (canvas.width-2*pad)\/2, pad);\n        c.lineTo(canvas.width-pad-innerR, pad);\n        c.arc(canvas.width-pad-innerR, pad+innerR, innerR, -Math.PI\/2, 0);\n        c.lineTo(canvas.width-pad, canvas.height-pad-innerR);\n        c.arc(canvas.width-pad-innerR, canvas.height-pad-innerR, innerR, 0, Math.PI\/2);\n        c.lineTo(pad+innerR, canvas.height-pad);\n        c.arc(pad+innerR, canvas.height-pad-innerR, innerR, Math.PI\/2, Math.PI);\n        c.lineTo(pad, pad+innerR);\n        c.arc(pad+innerR, pad+innerR, innerR, Math.PI, 3*Math.PI\/2);\n        c.closePath();\n        c.fill();\n      } else {\n        c.strokeStyle = outlineBG;\n        drawRoundedProgress(pad, pad, canvas.width - 2*pad, canvas.height - 2*pad, Math.max(0, radius - shadowPadding), 100);\n      }\n      \n      \n        c.restore();\n      \n        c.save();\n        let padding = lineWidth + shadowPadding;\n        let innerX = padding;\n        let innerY = padding;\n        let innerW = canvas.width - 2 * padding;\n        let innerH = canvas.height - 2 * padding;\n      \n        let innerR = radius - lineWidth\/2 - shadowPadding;\n        innerR = Math.max(0, innerR);\n        innerR = Math.min(innerR, innerW\/2, innerH\/2);\n      \n        c.beginPath();\n        if(innerR > 0){\n          c.moveTo(innerX + innerW\/2, innerY);\n          c.lineTo(innerX + innerW - innerR, innerY);\n          c.arc(innerX + innerW - innerR, innerY + innerR, innerR, -Math.PI\/2, 0);\n          c.lineTo(innerX + innerW, innerY + innerH - innerR);\n          c.arc(innerX + innerW - innerR, innerY + innerH - innerR, innerR, 0, Math.PI\/2);\n          c.lineTo(innerX + innerR, innerY + innerH);\n          c.arc(innerX + innerR, innerY + innerH - innerR, innerR, Math.PI\/2, Math.PI);\n          c.lineTo(innerX, innerY + innerR);\n          c.arc(innerX + innerR, innerY + innerR, innerR, Math.PI, 3*Math.PI\/2);\n          c.closePath();\n        } else {\n          c.rect(innerX, innerY, innerW, innerH);\n        }\n        c.clip();\n      \n        let imgW, imgH;\n        if(stretchImage){\n          imgW = innerW;\n          imgH = innerH;\n        } else {\n          let scale = Math.max(innerW \/ img.width, innerH \/ img.height);\n          imgW = img.width * scale;\n          imgH = img.height * scale;\n        }\n      \n        c.drawImage(img, innerX + (innerW - imgW)\/2, innerY + (innerH - imgH)\/2, imgW, imgH);\n        c.restore();\n      \n      \n        if(outlineGlowBlur > 0){\n          c.save();\n          c.strokeStyle = outlineGlowColor;\n          c.lineWidth = lineWidth;\n          c.lineCap = 'round';\n          c.shadowColor = outlineGlowColor;\n          c.shadowBlur = outlineGlowBlur;\n          c.shadowOffsetX = 0;\n          c.shadowOffsetY = 0;\n          \n          \n          let outlineGlowScale = 1\n          \n          let glowPad = pad + (canvas.width - 2*pad) * (1 - outlineGlowScale)\/2;\n        let glowWidth = (canvas.width - 2*pad) * outlineGlowScale;\n        let glowHeight = (canvas.height - 2*pad) * outlineGlowScale;\n        let glowRadius = Math.max(0, radius - shadowPadding) * outlineGlowScale;\n        \n          drawRoundedProgress(glowPad, glowPad, glowWidth, glowHeight, glowRadius, percent);\n        c.restore();\n      \n        }\n      \n        c.strokeStyle = createPattern(colourTL,colourTR,colourBL,colourBR);\n        drawRoundedProgress(pad, pad, canvas.width - 2*pad, canvas.height - 2*pad, Math.max(0, radius - shadowPadding), percent);\n      \n        try{\n          window.finalImage = canvas.toDataURL(\"image\/png\");\n        }catch(e){\n          window.finalImage = null;\n        }\n      };\n      img.onerror = ()=>{ window.finalImage = null; };\n      <\/script>\n      <\/body>\n      <\/html>\n    `;\n\n    let wv = new WebView();\n    await wv.loadHTML(html);\n    let dataUrl = await wv.evaluateJavaScript(\"window.finalImage\");\n    let req = new Request(dataUrl);\n    let img = await req.loadImage();\n\n    if (this.onStack) {\n      let newStack = this.onStack.addStack()\n      newStack.addImage(img)\n      if (this.showBounds) {\n        newStack.borderWidth = 2\n        newStack.borderColor = Color.blue()\n      }\n      newStack.size = new Size(this.width, this.height)\n      return newStack\n    }\n    else {\n      return img\n    }\n  }\n}\n\n\nasync function invertColor(input) { \/\/in: base64 mit\/ohne header, Image, url, hex 3\/6 mit\/ohne #, Color; out: #hex6\/Image\n    async function getBase64(str) {\n      if (\/^https?:\\\/\\\/\/.test(str)) {\n          let img = await new Request(str).loadImage()\n          return Data.fromPNG(img).toBase64String()\n      } else if (str instanceof Image) {\n          return Data.fromPNG(str).toBase64String()\n      } else {\n          return str.startsWith(\"data:image\") ? str.split(',')[1] : str\n      }\n  }\n    if (\/^#?([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$\/.test(cleanColor(input, true))) {\n        let hex = cleanColor(input)\n        let r = 255 - parseInt(hex.slice(1, 3), 16)\n        let g = 255 - parseInt(hex.slice(3, 5), 16)\n        let b = 255 - parseInt(hex.slice(5, 7), 16)\n        return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`\n    } else {\n        let base64 = await getBase64(input)\n        let html = `\n        <canvas id=\"canvas\"><\/canvas>\n        <script>\n        let img = new Image()\n        img.src = \"data:image\/png;base64,${base64}\"\n        img.onload = () => {\n            let canvas = document.getElementById('canvas')\n            canvas.width = img.width\n            canvas.height = img.height\n            let ctx = canvas.getContext('2d')\n            ctx.drawImage(img,0,0)\n            let imageData = ctx.getImageData(0,0,canvas.width,canvas.height)\n            let data = imageData.data\n            for(let i=0;i<data.length;i+=4){\n                data[i] = 255 - data[i]\n                data[i+1] = 255 - data[i+1]\n                data[i+2] = 255 - data[i+2]\n            }\n            ctx.putImageData(imageData,0,0)\n            window.finalImage = canvas.toDataURL('image\/png')\n        }\n        <\/script>\n        `\n        let wv = new WebView()\n        await wv.loadHTML(html)\n        let result = await wv.evaluateJavaScript(\"window.finalImage\")\n        return Image.fromData(Data.fromBase64String(result.split(',')[1]))\n    }\n}\n\n\nfunction getContrastColor(hex) { \/\/in: hex 3\/6 mit\/ohne #, Color; out: #hex6 \n    hex = cleanColor(hex).replace(\"#\", \"\")\n    let r = parseInt(hex.slice(0, 2), 16) \/ 255;\n    let g = parseInt(hex.slice(2, 4), 16) \/ 255;\n    let b = parseInt(hex.slice(4, 6), 16) \/ 255;\n\n    r = r <= 0.03928 ? r \/ 12.92 : Math.pow((r + 0.055)\/1.055, 2.4);\n    g = g <= 0.03928 ? g \/ 12.92 : Math.pow((g + 0.055)\/1.055, 2.4);\n    b = b <= 0.03928 ? b \/ 12.92 : Math.pow((b + 0.055)\/1.055, 2.4);\n\n    let luminance = 0.2126*r + 0.7152*g + 0.0722*b;\n    return luminance > 0.179 ? '#000000' : '#ffffff';\n}\n\n\nfunction cleanColor(newColor, nullOutput = false) { \/\/in: hex 3\/6 mit\/ohne #, Color; out: #hex6\n  if(newColor instanceof Color) newColor = newColor.hex\n  newColor = String(newColor).replace(\"#\", \"\")\n  let cleanColor = `${(newColor.hex ?? String(newColor)).replace(\/^#\/, \"\")}`\n  if(\/([0-9A-Fa-f]{6})$\/.test(cleanColor)) return \"#\" + cleanColor\n  else if(\/([0-9A-Fa-f]{3})$\/.test(cleanColor)) return `#${cleanColor[0]}${cleanColor[0]}${cleanColor[1]}${cleanColor[1]}${cleanColor[2]}${cleanColor[2]}`\n  else return nullOutput ? null : \"#ff00ff\"\n}\n\n\nasync function hueShift(input, degrees) { \/\/in: base64 mit\/ohne header, Image, url, hex 3\/6 mit\/ohne #, Color; out: #hex6\/Image\n    async function getBase64(str) {\n        if (\/^https?:\\\/\\\/\/.test(str)) {\n            let img = await new Request(str).loadImage()\n            return Data.fromPNG(img).toBase64String()\n        } else if (str instanceof Image) {\n            return Data.fromPNG(str).toBase64String()\n        } else {\n            return str.startsWith(\"data:image\") ? str.split(',')[1] : str\n        }\n    }\n\n    if (\/^#?([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$\/.test(cleanColor(input, true))) {\n        let hex = cleanColor(input)\n        let r = parseInt(hex.slice(1, 3), 16) \/ 255\n        let g = parseInt(hex.slice(3, 5), 16) \/ 255\n        let b = parseInt(hex.slice(5, 7), 16) \/ 255\n\n        let max = Math.max(r, g, b)\n        let min = Math.min(r, g, b)\n        let delta = max - min\n\n        let h\n        if (delta === 0) h = 0\n        else if (max === r) h = ((g - b) \/ delta) % 6\n        else if (max === g) h = (b - r) \/ delta + 2\n        else h = (r - g) \/ delta + 4\n        h *= 60\n        if (h < 0) h += 360\n\n        h = (h + degrees) % 360\n\n        let l = (max + min) \/ 2\n        let s = delta === 0 ? 0 : delta \/ (1 - Math.abs(2 * l - 1))\n\n        let c = (1 - Math.abs(2 * l - 1)) * s\n        let x = c * (1 - Math.abs((h \/ 60) % 2 - 1))\n        let m = l - c \/ 2\n        let r1, g1, b1\n        if (h < 60) [r1, g1, b1] = [c, x, 0]\n        else if (h < 120) [r1, g1, b1] = [x, c, 0]\n        else if (h < 180) [r1, g1, b1] = [0, c, x]\n        else if (h < 240) [r1, g1, b1] = [0, x, c]\n        else if (h < 300) [r1, g1, b1] = [x, 0, c]\n        else [r1, g1, b1] = [c, 0, x]\n\n        return `#${Math.round((r1 + m) * 255).toString(16).padStart(2,'0')}${Math.round((g1 + m) * 255).toString(16).padStart(2,'0')}${Math.round((b1 + m) * 255).toString(16).padStart(2,'0')}`\n    } else {\n        let base64 = await getBase64(input)\n        let html = `\n        <canvas id=\"canvas\"><\/canvas>\n        <script>\n        let img = new Image()\n        img.src = \"data:image\/png;base64,${base64}\"\n        img.onload = () => {\n            let canvas = document.getElementById('canvas')\n            canvas.width = img.width\n            canvas.height = img.height\n            let ctx = canvas.getContext('2d')\n            ctx.drawImage(img,0,0)\n            let imageData = ctx.getImageData(0,0,canvas.width,canvas.height)\n            let data = imageData.data\n            let angle = ${degrees} * Math.PI \/ 180\n            for(let i=0;i<data.length;i+=4){\n                let r=data[i]\/255,g=data[i+1]\/255,b=data[i+2]\/255\n                let max=Math.max(r,g,b),min=Math.min(r,g,b),delta=max-min\n                let l=(max+min)\/2\n                let s=delta===0?0:delta\/(1-Math.abs(2*l-1))\n                let h=0\n                if(delta!==0){\n                    if(max===r) h=((g-b)\/delta)%6\n                    else if(max===g) h=(b-r)\/delta+2\n                    else h=(r-g)\/delta+4\n                    h*=60\n                    if(h<0) h+=360\n                }\n                h=(h+${degrees})%360\n                let c=(1-Math.abs(2*l-1))*s\n                let x=c*(1-Math.abs((h\/60)%2-1))\n                let m=l-c\/2\n                let r1,g1,b1\n                if(h<60)[r1,g1,b1]=[c,x,0]\n                else if(h<120)[r1,g1,b1]=[x,c,0]\n                else if(h<180)[r1,g1,b1]=[0,c,x]\n                else if(h<240)[r1,g1,b1]=[0,x,c]\n                else if(h<300)[r1,g1,b1]=[x,0,c]\n                else [r1,g1,b1]=[c,0,x]\n                data[i]=Math.round((r1+m)*255)\n                data[i+1]=Math.round((g1+m)*255)\n                data[i+2]=Math.round((b1+m)*255)\n            }\n            ctx.putImageData(imageData,0,0)\n            window.finalImage = canvas.toDataURL('image\/png')\n        }\n        <\/script>\n        `\n        let wv = new WebView()\n        await wv.loadHTML(html)\n        let result = await wv.evaluateJavaScript(\"window.finalImage\")\n        return Image.fromData(Data.fromBase64String(result.split(',')[1]))\n    }\n}\n\n\nasync function averageColor(input) { \/\/in: base64 mit\/ohne header, Image, url, array mit hex 3\/6 mit\/ohne #, Color; out: #hex6\n    function getRGB(hex) {\n        hex = cleanColor(hex) \n        return [\n            parseInt(hex.slice(1, 3), 16),\n            parseInt(hex.slice(3, 5), 16),\n            parseInt(hex.slice(5, 7), 16)\n        ]\n    }\n\n    async function getBase64(str) {\n        if (\/^https?:\\\/\\\/\/.test(str)) {\n            let img = await new Request(str).loadImage()\n            return Data.fromPNG(img).toBase64String()\n        } else if (str instanceof Image) {\n            return Data.fromPNG(str).toBase64String()\n        } else {\n            return str.startsWith(\"data:image\") ? str.split(',')[1] : str\n        }\n    }\n\n    if (Array.isArray(input)) {\n        let r = 0, g = 0, b = 0\n        for (let color of input) {\n            let [r1, g1, b1] = getRGB(color)\n            r += r1\n            g += g1\n            b += b1\n        }\n        let len = input.length\n        r = Math.round(r \/ len)\n        g = Math.round(g \/ len)\n        b = Math.round(b \/ len)\n        return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`\n    } else if (\/^#?([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$\/.test(cleanColor(input, true))) {\n        return cleanColor(input, false)\n    } else {\n        let base64 = await getBase64(input)\n        let html = `\n        <canvas id=\"canvas\"><\/canvas>\n        <script>\n        let img = new Image()\n        img.src = \"data:image\/png;base64,${base64}\"\n        img.onload = () => {\n            let canvas = document.getElementById('canvas')\n            canvas.width = img.width\n            canvas.height = img.height\n            let ctx = canvas.getContext('2d')\n            ctx.drawImage(img,0,0)\n            let data = ctx.getImageData(0,0,canvas.width,canvas.height).data\n            let r=0,g=0,b=0\n            let len = data.length \/ 4\n            for(let i=0;i<data.length;i+=4){\n                r += data[i]\n                g += data[i+1]\n                b += data[i+2]\n            }\n            r = Math.round(r\/len)\n            g = Math.round(g\/len)\n            b = Math.round(b\/len)\n            window.avgColor = \"#\" + r.toString(16).padStart(2,'0') + g.toString(16).padStart(2,'0') + b.toString(16).padStart(2,'0')\n        }\n        <\/script>\n        `\n        let wv = new WebView()\n        await wv.loadHTML(html)\n        return await wv.evaluateJavaScript(\"window.avgColor\")\n    }\n}\n\n\nasync function adjustBrightness(input, amount) { \/\/in: base64 mit\/ohne header, Image, url, hex 3\/6 mit\/ohne #, Color; out: #hex6\/Image\n    async function getBase64(str) {\n        if (\/^https?:\\\/\\\/\/.test(str)) {\n            let img = await new Request(str).loadImage()\n            return Data.fromPNG(img).toBase64String()\n        } else if (str instanceof Image) {\n            return Data.fromPNG(str).toBase64String()\n        } else {\n            return str.startsWith(\"data:image\") ? str.split(',')[1] : str\n        }\n    }\n\n    function clamp(v) {\n        return Math.min(1, Math.max(0, v))\n    }\n\n    if (\/^#?([0-9A-Fa-f]{3}|[0-9A-Fa-f]{6})$\/.test(cleanColor(input, true))) {\n        let hex = cleanColor(input)\n        let r = parseInt(hex.slice(1, 3), 16) \/ 255\n        let g = parseInt(hex.slice(3, 5), 16) \/ 255\n        let b = parseInt(hex.slice(5, 7), 16) \/ 255\n\n        r = clamp(r + amount)\n        g = clamp(g + amount)\n        b = clamp(b + amount)\n\n        return `#${Math.round(r * 255).toString(16).padStart(2,'0')}${Math.round(g * 255).toString(16).padStart(2,'0')}${Math.round(b * 255).toString(16).padStart(2,'0')}`\n    } else {\n        let base64 = await getBase64(input)\n        let html = `\n        <canvas id=\"canvas\"><\/canvas>\n        <script>\n        let img = new Image()\n        img.src = \"data:image\/png;base64,${base64}\"\n        img.onload = () => {\n            let canvas = document.getElementById('canvas')\n            canvas.width = img.width\n            canvas.height = img.height\n            let ctx = canvas.getContext('2d')\n            ctx.drawImage(img,0,0)\n            let imageData = ctx.getImageData(0,0,canvas.width,canvas.height)\n            let data = imageData.data\n            for(let i=0;i<data.length;i+=4){\n                data[i] = Math.min(255, Math.max(0, data[i] + ${Math.round(amount*255)}))\n                data[i+1] = Math.min(255, Math.max(0, data[i+1] + ${Math.round(amount*255)}))\n                data[i+2] = Math.min(255, Math.max(0, data[i+2] + ${Math.round(amount*255)}))\n            }\n            ctx.putImageData(imageData,0,0)\n            window.finalImage = canvas.toDataURL('image\/png')\n        }\n        <\/script>\n        `\n        let wv = new WebView()\n        await wv.loadHTML(html)\n        let result = await wv.evaluateJavaScript(\"window.finalImage\")\n        return Image.fromData(Data.fromBase64String(result.split(',')[1]))\n    }\n}\n\n\nfunction createRandomColor(seed) { \/\/in: any string or number; out: #hex6\n    if(seed == null) seed = new Date().getMilliseconds()\n    seed = String(seed)\n    let hash = 0\n    for (let i = 0; i < seed.length; i++) {\n        hash = seed.charCodeAt(i) + ((hash << 5) - hash)\n        hash |= 0\n    }\n\n    let h = Math.abs(hash) % 360\n    let s = 60 + (Math.abs(hash >> 8) % 25) \/\/ 60–80%\n    let l = 50 + (Math.abs(hash >> 16) % 10) \/\/ 50–60%\n\n    function hslToHex(h, s, l) {\n        s \/= 100\n        l \/= 100\n        let c = (1 - Math.abs(2 * l - 1)) * s\n        let x = c * (1 - Math.abs((h \/ 60) % 2 - 1))\n        let m = l - c\/2\n        let r1, g1, b1\n        if(h < 60) [r1,g1,b1] = [c,x,0]\n        else if(h < 120) [r1,g1,b1] = [x,c,0]\n        else if(h < 180) [r1,g1,b1] = [0,c,x]\n        else if(h < 240) [r1,g1,b1] = [0,x,c]\n        else if(h < 300) [r1,g1,b1] = [x,0,c]\n        else [r1,g1,b1] = [c,0,x]\n        let r = Math.round((r1 + m)*255).toString(16).padStart(2,'0')\n        let g = Math.round((g1 + m)*255).toString(16).padStart(2,'0')\n        let b = Math.round((b1 + m)*255).toString(16).padStart(2,'0')\n        return `#${r}${g}${b}`\n    }\n\n    return hslToHex(h, s, l)\n}\n\n\nmodule.exports = { FancyText, FancyImage, invertColor, getContrastColor, hueShift, cleanColor, averageColor, adjustBrightness, createRandomColor}",
