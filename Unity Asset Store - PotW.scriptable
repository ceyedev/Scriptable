{
  "always_run_in_app" : false,
  "icon" : {
    "color" : "deep-blue",
    "glyph" : "user-graduate"
  },
  "name" : "Unity Asset Store - PotW",
  "script" : "\/\/Created by ceyedev\n\/\/V1.4\n\nlet baseModule = importModule(\"Base\")\n\nlet html = await new Request(\"https:\/\/assetstore.unity.com\/publisher-sale\").loadString()\n\n\nlet publisherName = html.match(new RegExp('<span class=\"caption mb-5 block text-white\">([^<]+)<\/span>'))[1].replace(\"asset giveaway\", \"\")\nlet nameAndCoupon = html.match(new RegExp('<span class=\"body mt-5 block text-white\">Add ([^<]+) to your cart, then enter the coupon code ([^<]+) at checkout to get it for free.'))\nlet assetName = nameAndCoupon[1]\nlet couponName = nameAndCoupon[2]\nlet offerTimeRaw = html.match(new RegExp('<p class=\"truncate text-sm\">[^<]+ end ([^<]+) PT.<\/p>'))[1]\nlet assetImageUrl = html.match(\/<div class=\"main-grid\">([\\s\\S]*?)<img[^>]*src=\"([^\"]+)\"\/)[2]\n\n\n\nlet ptFormatter = new DateFormatter()\nptFormatter.locale = \"en\"\nptFormatter.dateFormat = \"MMMM d, yyyy 'at' h:mma\"\nlet date = ptFormatter.date(offerTimeRaw)\n\nlet berlinTime = new Date(date.getTime() + 9 * 60 * 60 * 1000)\nlet deFormatter = new DateFormatter()\ndeFormatter.locale = \"en\"\ndeFormatter.dateFormat = \"HH:mm, EEEE d. MMM\"\n\nlet now = new Date()\nlet diff = berlinTime - now\nlet minutes = Math.round(diff \/ 1000 \/ 60)\nlet hours = Math.round((minutes \/ 60) * 10) \/ 10\nlet days = Math.round(hours \/ 24)\nlet result\nif (days >= 1) {\n    result = days + (days == 1 ? \" Day\" : \" Days\");\n} else if (hours >= 1) {\n    result = hours + (hours == 1 ? \" Hour\" : \" Hours\");\n} else {\n    result = minutes + (minutes == 1 ? \" Minute\" : \" Minutes\");\n}\n\nlet offerTime = deFormatter.string(berlinTime) + \" (\" + result + \")\"\nconsole.log(result)\n\n\nprint(assetName)\nprint(publisherName)\nprint(couponName)\nprint(offerTimeRaw)\nprint(offerTime)\nprint(assetImageUrl)\n\n\n\nconst widget = new ListWidget();\nwidget.setPadding(10, 20, 5, 20)\n\n\nif (assetImageUrl) {\n    try {\n        const imgReq = new Request(assetImageUrl);\n        const image = await imgReq.loadImage();\n        widget.backgroundImage = image;\n    } catch (e) {\n        console.log(\"Error while loading the BG image\");\n    }\n}\n\n\nlet gradient = new LinearGradient()\ngradient.startPoint = new Point(0, 0)\ngradient.endPoint = new Point(1, 0)\ngradient.locations = [0.33, 1]\ngradient.colors = [new Color(\"000000\", 0), new Color(\"000000\", 0.75)]\n\nwidget.backgroundGradient = gradient;\n\n\nlet mainStack = widget.addStack()\nmainStack.layoutVertically()\n\n\nlet headerStack = mainStack.addStack()\nheaderStack.layoutHorizontally()\nheaderStack.addSpacer()\ncreateGradientText(headerStack, assetName, 30, new Color(\"8CFF9B\"), new Color(\"42BC7F\"), \"bold\", 0, true)\n\/\/await new baseModule.FancyText().setText(assetName).setStack(headerStack).setSize(280, 30).setFontColor(\"8CFF9B\", \"42BC7F\").setAlign(\"right\", \"middle\").setShadow(\"000\",2,2,6).create()\n\n\nlet publisherStack = mainStack.addStack()\npublisherStack.size = new Size(publisherStack.size.width, 25)\npublisherStack.layoutHorizontally()\npublisherStack.addSpacer()\ncreateGradientText(publisherStack, publisherName, 20, new Color(\"50B9EB\"), new Color(\"3E83D1\"), \"bold\", 0, true)\n\n\nmainStack.addSpacer()\n\n\nlet couponStack = mainStack.addStack()\ncouponStack.size = new Size(couponStack.size.width, 16)\ncouponStack.layoutHorizontally()\ncouponStack.addSpacer()\ncreateGradientText(couponStack, \"Code: \" + couponName, 12, new Color(\"FFE091\"), new Color(\"FFAA6E\"), \"bold\", 0, true)\n\n\nlet dateStack = mainStack.addStack()\ndateStack.size = new Size(dateStack.size.width, 16)\ndateStack.layoutHorizontally()\ndateStack.addSpacer()\ncreateGradientText(dateStack, offerTime, 12, new Color(\"909EDD\"), new Color(\"6B74B2\"), \"bold\", 0, true)\n\n\nwidget.addSpacer()\n\nScript.setWidget(widget);\nwidget.presentMedium()\nScript.complete();\n\n\nfunction print(input) {console.log(input)}\n\n\nfunction createGradientText(stack, textContent, fontSize, fontColorFrom, fontColorTo, fontWeight, lineLimit, autoSize = false){\n\n  if(autoSize){\n    fontSize = calcSize(fontSize, 10, 8, 50, textContent.length) \n  }\n\n  function calcSize(sizeMax, sizeMin, charsMin, charsMax, charCurrent) {\n    if (charCurrent <= charsMin) return sizeMax\n    if (charCurrent >= charsMax) return sizeMin\n    let t = (charCurrent - charsMin) \/ (charsMax - charsMin)\n    return sizeMax - t * (sizeMax - sizeMin)\n  }\n\n  function floatToHex(f){\n    f = Math.max(0, Math.min(1, f))\n    let v = Math.round(f * 255)\n    return v.toString(16).padStart(2, \"0\")\n  }\n  function rgbToHex(r,g,b){\n    return \"#\" + floatToHex(r) + floatToHex(g) + floatToHex(b)\n  }\n\n  function lerpColor(c1, c2, t){\n    let [r1,g1,b1] = [c1.red, c1.green, c1.blue]\n    let [r2,g2,b2] = [c2.red, c2.green, c2.blue]\n    let r = parseFloat((r1 + (r2-r1)*t).toFixed(5))\n    let g = parseFloat((g1 + (g2-g1)*t).toFixed(5))\n    let b = parseFloat((b1 + (b2-b1)*t).toFixed(5))\n\n    return rgbToHex(r, g, b)\n  }\n\n  let x = 0\n  for(let i=0; i<textContent.length; i++){\n    let t = textContent.length > 1 ? i\/(textContent.length-1) : 0\n    createText(stack, textContent[i], fontSize, new Color(lerpColor(fontColorFrom,fontColorTo,t)), fontWeight, lineLimit)\n    stack.addSpacer(0.25)\n  }\n  stack.addSpacer(1)\n\n}\n\nfunction createText(stack, textContent, fontSize, fontColor, fontWeight, lineLimit){\n\tlet text = stack.addText(textContent)\n\ttext.textColor = fontColor\n\ttext.font = fontWeight == \"bold\" ? Font.boldSystemFont(Number(fontSize)) : Font.systemFont(Number(fontSize))\n\ttext.lineLimit = lineLimit\n\t\n\ttext.shadowOffset = new Point(1.5, 1.5)\n\ttext.shadowColor = Color.black()\n\ttext.shadowRadius = 2\n  return text\n}\n\nfunction createSymbol(stack, name, tintColor){\n  let s = SFSymbol.named(name)\n  s.applyFont(Font.boldSystemFont(20))\n  let iconSymbol = s.image\n  let iconStack = stack.addImage(iconSymbol)\n  iconStack.tintColor = tintColor\n  iconStack.imageSize = new Size(20,20)\n  stack.addSpacer(4)\n}",
  "share_sheet_inputs" : [

  ]
}